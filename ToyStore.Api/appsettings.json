{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=ToyStoreDb;Trusted_Connection=True;MultipleActiveResultSets=true"
  },
  "Jwt": {
    "Issuer": "ToyStoreApi",
    "Audience": "ToyStoreClients",
    "ExpiryMinutes": 30,
    "EnableSlidingExpiration": true
  },

  "Pagination": {
    "DefaultPageSize": 10,
    "MaxPageSize": 50
  },
    "Cors": {
      "AllowedOrigin": "https://localhost:7080"
    },
    "ApiSettings": {
      "BaseUrl": "https://localhost:7223"
    }
}