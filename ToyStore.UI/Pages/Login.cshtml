@page
@model ToyStore.UI.Pages.LoginModel
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Giriş Yap - ToyStore</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
        theme: { extend: { colors: { brand: '#2563eb' } } }
        }
    </script>
</head>
<body class="bg-slate-900 h-screen flex items-center justify-center">

    <div class="bg-white p-8 rounded-lg shadow-2xl w-full max-w-md">
        <div class="text-center mb-8">
            <h1 class="text-3xl font-bold text-slate-900">ToyStore'a Hoş Geldiniz</h1>
            <p class="text-gray-500 mt-2">Hesabınıza erişmek için e-posta ve şifrenizi girin.</p>
        </div>

        <form id="loginForm" onsubmit="window.handleLogin(event)">
            <div id="loginError" class="hidden bg-red-100 border-l-4 border-red-500 text-red-700 p-3 mb-4 text-sm rounded" role="alert">
                Kullanıcı adı veya şifre hatalı.
            </div>

            <div class="mb-4">
                <label for="email" class="block text-sm font-medium text-gray-700">E-Posta Adresi</label>
                <input type="email" id="email" required class="mt-1 block w-full px-3 py-2 bg-white border border-gray-300 rounded-md text-sm shadow-sm placeholder-gray-400 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500" placeholder="ornek@toystore.com">
            </div>

            <div class="mb-6">
                <label for="password" class="block text-sm font-medium text-gray-700">Şifre</label>
                <input type="password" id="password" required class="mt-1 block w-full px-3 py-2 bg-white border border-gray-300 rounded-md text-sm shadow-sm placeholder-gray-400 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500" placeholder="••••••••">
            </div>

            <button type="submit" id="loginBtn" class="w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors">
                Giriş Yap
            </button>
        </form>

        <div class="mt-6 text-center text-sm text-gray-600 border-t pt-4 border-gray-100">
            Hesabınız yok mu?
            <a href="/Register" class="font-medium text-blue-600 hover:text-blue-500 transition-colors">Hemen kayıt olun</a>
        </div>
    </div>

    <!-- 1. ADIM: Güvenlik Zırhı ve AppConfig Yapılandırması -->
    <script>
        // GÜVENLİK ADIMI: Oturum açıkken Login formunu bypass etme zırhı
        (function() {
        // Yeni Zırh
        const token = localStorage.getItem("token");
        if (token) {
        window.location.replace("/Dashboard");
        }
        })();

        window.AppConfig = {
        Pagination: {
        DefaultSize: Number("@Configuration["Pagination:DefaultPageSize"]") || 10,
        MaxSize: Number("@Configuration["Pagination:MaxPageSize"]") || 50
        },
        ApiUrl: "@Configuration["ApiSettings:BaseUrl"]" || "https://localhost:7223"
        };
    </script>

    <!-- 2. ADIM: Sistem ve UI Kütüphaneleri -->
    <script src="~/js/NotificationUI.js" asp-append-version="true"></script>
    <script src="~/js/api.js" asp-append-version="true"></script>
    <script src="~/js/auth/LoginUI.js" asp-append-version="true"></script>

    <!-- Giriş Yapma Orkestratör Kodu -->
    <script>


        window.handleLogin = async function (event) {
        event.preventDefault();

        const email = document.getElementById('email').value;
        const password = document.getElementById('password').value;

        LoginUI.setLoading(true);
        LoginUI.hideError();

        try {
        const response = await window.apiFetch(window.API_ROUTES.AUTH.LOGIN, {
        method: "POST",
        body: JSON.stringify({ email: email, password: password })
        });

        if (response && response.ok) {
        const data = await response.json();
        localStorage.setItem("token", data.token);

        // Kullanıcıyı doğrudan rol bazlı analiz paneline fırlatıyoruz
        window.location.replace("/Dashboard");
        }
        } catch (error) {
        console.error("Login hatası:", error);
        } finally {
        LoginUI.setLoading(false);
        }
        }
    </script>
</body>
</html>