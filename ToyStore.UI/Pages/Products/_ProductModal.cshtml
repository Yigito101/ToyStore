<!-- Arka plan örtüsü ve Modal Container -->
<div id="productModal" class="fixed inset-0 z-50 hidden overflow-y-auto" aria-labelledby="modal-title" role="dialog" aria-modal="true">
    <div class="flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">

        <!-- Saydam Arka Plan (GÜNCELLENDİ: ProductUI.closeModal eklendi) -->
        <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity" aria-hidden="true" onclick="ProductUI.closeModal()"></div>

        <!-- Dikey Hizalama Hilesi -->
        <span class="hidden sm:inline-block sm:align-middle sm:h-screen" aria-hidden="true">&#8203;</span>

        <!-- Beyaz Modal Kutusu -->
        <div class="inline-block align-bottom bg-white rounded-lg text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-lg sm:w-full">

            <!-- GÜNCELLENDİ: window.saveProduct'a bağlandı -->
            <form id="productForm" onsubmit="window.saveProduct(event)">
                <div class="bg-white px-4 pt-5 pb-4 sm:p-6 sm:pb-4">
                    <h3 class="text-lg leading-6 font-medium text-gray-900 mb-4" id="productModalLabel">Yeni Ürün Ekle</h3>

                    <!-- Temel Gizli Alanlar -->
                    <input type="hidden" id="productId" value="0">
                    <input type="hidden" id="productRowVersion" value="">
                    <input type="hidden" id="productIsActive" value="true"> <!-- JS'in hata vermemesi için -->
                    <!-- YENİ: Kirlilik (Dirty) Kontrolü İçin Orijinal Değerler -->
                    <input type="hidden" id="originalProductName" value="">
                    <input type="hidden" id="originalProductCategoryId" value="">
                    <input type="hidden" id="originalProductPrice" value="">
                    <input type="hidden" id="originalProductStock" value="">
                    <input type="hidden" id="originalProductIsActive" value="">

                    <div class="mb-4">
                        <label for="productName" class="block text-sm font-medium text-gray-700">Ürün Adı</label>
                        <input type="text" id="productName" required maxlength="100" class="mt-1 focus:ring-blue-500 focus:border-blue-500 block w-full shadow-sm sm:text-sm border-gray-300 rounded-md py-2 px-3 border">
                    </div>

                    <div class="mb-4">
                        <label for="productCategory" class="block text-sm font-medium text-gray-700">Kategori</label>
                        <select id="productCategory" required class="mt-1 block w-full py-2 px-3 border border-gray-300 bg-white rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500 sm:text-sm">
                            <option value="">Seçiniz...</option>
                        </select>
                    </div>

                    <div class="grid grid-cols-2 gap-4 mb-4">
                        <div>
                            <label for="productPrice" class="block text-sm font-medium text-gray-700">Fiyat (₺)</label>
                            <input type="number" step="0.01" min="0" id="productPrice" required class="mt-1 focus:ring-blue-500 focus:border-blue-500 block w-full shadow-sm sm:text-sm border-gray-300 rounded-md py-2 px-3 border">
                        </div>
                        <div>
                            <label for="productStock" class="block text-sm font-medium text-gray-700">Stok Adedi</label>
                            <input type="number" id="productStock" required min="0" class="mt-1 focus:ring-blue-500 focus:border-blue-500 block w-full shadow-sm sm:text-sm border-gray-300 rounded-md py-2 px-3 border">
                        </div>
                    </div>
                </div>

                <!-- Alt Butonlar -->
                <div class="bg-gray-50 px-4 py-3 sm:px-6 sm:flex sm:flex-row-reverse">
                    <button type="submit" class="w-full inline-flex justify-center rounded-md border border-transparent shadow-sm px-4 py-2 bg-blue-600 text-base font-medium text-white hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 sm:ml-3 sm:w-auto sm:text-sm">
                        Kaydet
                    </button>
                    <!-- GÜNCELLENDİ: İptal butonu ProductUI.closeModal'a bağlandı -->
                    <button type="button" onclick="ProductUI.closeModal()" class="mt-3 w-full inline-flex justify-center rounded-md border border-gray-300 shadow-sm px-4 py-2 bg-white text-base font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 sm:mt-0 sm:ml-3 sm:w-auto sm:text-sm">
                        İptal
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>