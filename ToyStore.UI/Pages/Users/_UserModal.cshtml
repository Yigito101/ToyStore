<div id="userModal" class="fixed inset-0 z-50 hidden overflow-y-auto" aria-labelledby="modal-title" role="dialog" aria-modal="true">
    <div class="flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">

        <!-- Arka plan tıklandığında UserUI üzerinden kapatıyoruz -->
        <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity" aria-hidden="true" onclick="UserUI.closeModal()"></div>
        <span class="hidden sm:inline-block sm:align-middle sm:h-screen" aria-hidden="true">&#8203;</span>

        <div class="inline-block align-bottom bg-white rounded-lg text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-lg sm:w-full">

            <!-- GÜNCELLEME: onsubmit'i window.saveUserForm'a bağladık -->
            <form id="userForm" onsubmit="window.saveUserForm(event)">
                <div class="bg-white px-4 pt-5 pb-4 sm:p-6 sm:pb-4">
                    <h3 class="text-lg leading-6 font-medium text-gray-900 mb-4" id="userModalLabel">Yeni Kullanıcı Ekle</h3>

                    <!-- HATA KUTUSU -->
                    <div id="userModalError" class="hidden mb-4 p-3 text-sm text-red-700 bg-red-100 rounded border border-red-200"></div>

                    <!-- GİZLİ GİRDİLER -->
                    <input type="hidden" id="userId" value="0">
                    <input type="hidden" id="originalUserRole" value="">

                    <div class="mb-4">
                        <label for="userEmail" class="block text-sm font-medium text-gray-700">E-Posta</label>
                        <input type="email" id="userEmail" required class="mt-1 focus:ring-blue-500 focus:border-blue-500 block w-full shadow-sm sm:text-sm border-gray-300 rounded-md py-2 px-3 border">
                    </div>

                    <div class="mb-4">
                        <label for="userPassword" class="block text-sm font-medium text-gray-700">Şifre <span class="text-xs text-gray-500 font-normal" id="passwordHint"></span></label>
                        <input type="password" id="userPassword" class="mt-1 focus:ring-blue-500 focus:border-blue-500 block w-full shadow-sm sm:text-sm border-gray-300 rounded-md py-2 px-3 border">
                    </div>

                    <div class="mb-4">
                        <label for="confirmUserPassword" class="block text-sm font-medium text-gray-700">Şifre Tekrar</label>
                        <input type="password" id="confirmUserPassword" class="mt-1 focus:ring-blue-500 focus:border-blue-500 block w-full shadow-sm sm:text-sm border-gray-300 rounded-md py-2 px-3 border">
                    </div>

                    <div class="mb-4">
                        <label for="userRole" class="block text-sm font-medium text-gray-700">Sistem Rolü</label>
                        <select id="userRole" required class="mt-1 block w-full py-2 px-3 border border-gray-300 bg-white rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500 sm:text-sm">
                            <option value="Admin">Admin</option>
                            <option value="Manager">Yönetici</option>
                            <option value="User">Standart Kullanıcı</option>
                        </select>
                    </div>
                </div>

                <div class="bg-gray-50 px-4 py-3 sm:px-6 sm:flex sm:flex-row-reverse">
                    <button type="submit" class="w-full inline-flex justify-center rounded-md border border-transparent shadow-sm px-4 py-2 bg-blue-600 text-base font-medium text-white hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 sm:ml-3 sm:w-auto sm:text-sm">
                        Kaydet
                    </button>
                    <!-- GÜNCELLEME: İptal butonunu UserUI modülüne bağladık -->
                    <button type="button" onclick="UserUI.closeModal()" class="mt-3 w-full inline-flex justify-center rounded-md border border-gray-300 shadow-sm px-4 py-2 bg-white text-base font-medium text-gray-700 hover:bg-gray-50 sm:mt-0 sm:ml-3 sm:w-auto sm:text-sm">
                        İptal
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>